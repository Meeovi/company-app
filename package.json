      "@fortawesome/vue-fontawesome": "^3.1.3",
      "@mdi/font": "^7.4.47",
      "@nuxt/image": "^2.0.0",
      "@nuxtjs/leaflet": "^1.3.2",
      "@pinia/nuxt": "^0.11.3",
      "@vueuse/core": "^13.5.0",
      "eslint": "^10.0.3",
      "nuxt": "^4.3.1",
      "pinia": "^3.0.4",
      "vuetify-nuxt-module": "^1.0.0-alpha.3"
