   },
   "license": "MIT",
   "private": true,
   "scripts": {
      "company-commit": "git add . && git commit -m \"ready for update\"",
      "company-update": "git pull \"https://github.com/Meeovi/company-app\"",
      "build": "nuxt build",
      "dev": "nuxt dev",
      "ts-node": "ts-node -r tsconfig-paths/register --compiler-options '{\"module\":\"CommonJS\"}'",
      "generate": "nuxt generate",
      "preview": "nuxt preview",
      "postinstall": "nuxt prepare",
      "gqlg": "npx gqlg --schemaFilePath graphql/schema.graphql --destDirPath graphql/framework --depthLimit 2"
   },
   "dependencies": {
      "@directus/sdk": "^21.2.0",
